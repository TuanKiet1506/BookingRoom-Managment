{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/weekly-snapshot",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 */1 * * *"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  }
}
